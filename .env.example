# Copy this file to `.env` for local dev, and set the same variables in the
# Cloudflare Pages dashboard (Settings → Environment variables) for production.
#
# All VITE_-prefixed vars are embedded into the client bundle at BUILD time,
# so they are publicly visible. Only use keys that are safe to expose (the
# Supabase anon key and a browser-restricted Google Maps key) — never a
# service-role / server secret here.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
